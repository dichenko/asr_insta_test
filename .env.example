APP_ENV=production
APP_BASE_URL=https://api.instagram-ai.liven8n.site
PORT=8000
LOG_LEVEL=INFO

POSTGRES_DB=instagram_ai
POSTGRES_USER=instagram_ai
POSTGRES_PASSWORD=change_me

# Docker Compose builds DATABASE_URL from POSTGRES_* values.
# Use this only when running the app outside Docker Compose.
DATABASE_URL=postgresql+asyncpg://instagram_ai:change_me@localhost:5432/instagram_ai

TELEGRAM_BOT_TOKEN=
TELEGRAM_POLLING_ENABLED=true
TELEGRAM_POLLING_TIMEOUT=30
# Optional. Used only to show a "Return to Telegram" link on the OAuth success page.
TELEGRAM_BOT_USERNAME=

INSTAGRAM_CLIENT_ID=1034890592555471
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=https://api.instagram-ai.liven8n.site/auth/instagram/callback
INSTAGRAM_SCOPES=instagram_business_basic,instagram_business_manage_insights
INSTAGRAM_API_VERSION=v23.0

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=
